# Ollama server
OLLAMA_BASE_URL=http://localhost:11434

# ── Hybrid model architecture ─────────────────────────────────────────────────
# Citizens use the ultra-lightweight 0.5B model (fast, low CPU usage).
OLLAMA_CITIZEN_MODEL=qwen2.5-coder:0.5b
OLLAMA_CITIZEN_TIMEOUT=120

# Government agents use the higher-intelligence 3B model (structural policy work).
OLLAMA_GOVERNMENT_MODEL=qwen2.5-coder:3b
OLLAMA_GOVERNMENT_TIMEOUT=180

# Legacy single-model override (used by get_llm() alias only).
OLLAMA_MODEL=autosociety-qwen
OLLAMA_TIMEOUT_SECONDS=240
